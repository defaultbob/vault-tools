# ============================================================
# vault-tools — environment configuration template
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.
# ============================================================

# -------------------------------------------------------
# Vault connection (shared by all tools)
# -------------------------------------------------------
VAULT_URL=https://your-vault.veevavault.com
VAULT_VERSION=v25.3
VAULT_USERNAME=you@domain.com
VAULT_PASSWORD=yourpassword

# Optional: pre-authenticated session ID (takes priority over username/password)
# Obtain via: POST /api/{version}/auth  — sessions expire, leave blank to auto-auth.
VAULT_SESSION=

# -------------------------------------------------------
# vault-ddapi — Direct Data API sync
# Use absolute paths (required for cron/launchd)
# -------------------------------------------------------
DB_PATH=/absolute/path/to/vault-tools/data/vault.db
LOG_PATH=/absolute/path/to/vault-tools/vault-ddapi/logs/ddapi.log
WORK_DIR=/absolute/path/to/vault-tools/vault-ddapi/data

# Optional vault-ddapi settings (defaults shown)
# EXTRACT_TYPE=incremental   # set to 'full' to force a full re-seed on next run
# MAX_RETRIES=3
# RETRY_BACKOFF_SECONDS=5
